# Copy to .env and replace every placeholder before starting.

TZ=Europe/Berlin
GENERIC_TIMEZONE=Europe/Berlin

N8N_IMAGE_TAG=latest
N8N_PORT=5678
N8N_UID=1000
N8N_GID=1000
N8N_HOST=n8n.working-notes.org
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.working-notes.org/
N8N_EDITOR_BASE_URL=https://n8n.working-notes.org/

N8N_BASIC_AUTH_USER=change-me
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_ENCRYPTION_KEY=replace-with-32-plus-random-characters

POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me

OPENCLAW_BASE_URL=http://host.docker.internal:3001
OPENCLAW_TASK_ENDPOINT=/api/tasks
OPENCLAW_KANBAN_ENDPOINT=/api/kanban/tasks
OPENCLAW_DEFAULT_BOARD_ID=995cdcf8-3eda-4bb8-8ce2-c85a10791d95
OPENCLAW_DEFAULT_PROJECT_ID=rook-workspace
OPENCLAW_DEFAULT_RELATED_REPO=MarcusGraetsch/idp-customer-onboarding
OPENCLAW_DEFAULT_TARGET_STATUS=intake
OPENCLAW_WEBHOOK_SECRET=change-me

N8N_PUBLIC_API_DISABLED=false
N8N_SECURE_COOKIE=true
N8N_DIAGNOSTICS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false
EXECUTIONS_MODE=regular
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=336
EXECUTIONS_TIMEOUT=3600
N8N_LOG_LEVEL=info
