            "index": 0
          }
        ]
      ]
    },
    "Parse Telegram Intake": {
      "main": [
        [
          {
            "node": "Supported Intake Format?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Supported Intake Format?": {
      "main": [
        [
          {
            "node": "Create OpenClaw Task",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Send Format Hint",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Create OpenClaw Task": {
      "main": [
        [
          {
            "node": "Send Telegram Ack",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send Telegram Ack": {
      "main": []
    },
    "Send Format Hint": {
      "main": []
    }
  },
  "pinData": {},
  "meta": {
    "templateCredsSetupCompleted": false,
    "phase": "1",
    "notes": "Uses a dedicated Telegram automation bot webhook and the live OpenClaw kanban task API."
  },
